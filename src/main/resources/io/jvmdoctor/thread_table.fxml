<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="io.jvmdoctor.ui.ThreadTableController"
      spacing="8">
    <padding><Insets top="8" right="12" bottom="8" left="12"/></padding>

    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="Filter:"/>
        <TextField fx:id="filterField" promptText="thread name / state / lock…" prefWidth="300" HBox.hgrow="ALWAYS"/>
    </HBox>

    <SplitPane orientation="VERTICAL" dividerPositions="0.6" VBox.vgrow="ALWAYS">

        <TableView fx:id="threadTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="nameCol"  text="Thread Name"  prefWidth="320"/>
                <TableColumn fx:id="stateCol" text="State"        prefWidth="120"/>
                <TableColumn fx:id="lockCol"  text="Waiting On"   prefWidth="240"/>
                <TableColumn fx:id="depthCol" text="Stack Depth"  prefWidth="90" style="-fx-alignment: CENTER_RIGHT;"/>
            </columns>
            <placeholder>
                <Label text="No threads loaded. Open a dump file and click Analyze."/>
            </placeholder>
        </TableView>

        <TextArea fx:id="stackDetail" editable="false" wrapText="false"
                  promptText="Select a thread to view its stack trace"
                  style="-fx-font-family: monospace; -fx-font-size: 12px;"/>
    </SplitPane>
</VBox>
