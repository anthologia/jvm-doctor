<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<SplitPane orientation="VERTICAL" dividerPositions="0.6"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="io.jvmdoctor.ui.DumpDiffController"
           style="-fx-background-color: #1e1e2e;">

    <!-- TOP: diff table -->
    <VBox spacing="6">
        <padding><Insets top="8" right="12" bottom="4" left="12"/></padding>

        <Label fx:id="sessionLabel" text="Pair Diff compares the fixed anchor against one later loaded dump."
               styleClass="status-label"/>

        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="Source" styleClass="filter-label"/>
            <Label fx:id="anchorSnapshotLabel" text="Session anchor" styleClass="session-anchor-pill"/>
            <Label text="Target" styleClass="filter-label"/>
            <ComboBox fx:id="toSnapshotBox" prefWidth="210" promptText="Choose target snapshot"/>
            <Button fx:id="latestTargetBtn" text="Latest" styleClass="toolbar-btn, toolbar-btn-subtle"/>
        </HBox>

        <Label fx:id="summaryLabel" text="Choose a later dump from the target picker or the session rail on the right."
               styleClass="card-title"/>

        <!-- Filter chips + text filter -->
        <HBox spacing="8" alignment="CENTER_LEFT">
            <ToggleButton fx:id="showAdded"     text="+ Added"    styleClass="filter-chip, chip-runnable"/>
            <ToggleButton fx:id="showRemoved"   text="- Removed"  styleClass="filter-chip, chip-blocked"/>
            <ToggleButton fx:id="showChanged"   text="~ Changed"  styleClass="filter-chip, chip-waiting"/>
            <ToggleButton fx:id="showUnchanged" text="= Same"     styleClass="filter-chip"/>
            <TextField fx:id="filterField" promptText="filter by thread name…" HBox.hgrow="ALWAYS"/>
        </HBox>

        <TableView fx:id="diffTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="changeCol" text="Change" prefWidth="110" minWidth="90"/>
                <TableColumn fx:id="nameCol"   text="Thread Name" prefWidth="300" minWidth="150"/>
                <TableColumn fx:id="transitionCol" text="Boundary" prefWidth="170" minWidth="120"/>
                <TableColumn fx:id="signalsCol" text="Signals" prefWidth="220" minWidth="160"/>
                <TableColumn fx:id="beforeCol" text="Seen" prefWidth="90" minWidth="70"/>
                <TableColumn fx:id="afterCol"  text="Flips"  prefWidth="90" minWidth="70"/>
            </columns>
            <placeholder>
                <Label text="No pair diff yet. Start a session, then pick a later dump to compare against the anchor."/>
            </placeholder>
        </TableView>
    </VBox>

    <!-- BOTTOM: thread detail -->
    <VBox spacing="4">
        <padding><Insets top="6" right="12" bottom="8" left="12"/></padding>
        <Label text="THREAD DETAIL" styleClass="section-label"/>
        <TextArea fx:id="detailArea" styleClass="raw-area" editable="false"
                  wrapText="false" VBox.vgrow="ALWAYS"
                  style="-fx-font-family: monospace; -fx-font-size: 12px;"/>
    </VBox>

</SplitPane>
