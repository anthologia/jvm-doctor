<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="io.jvmdoctor.ui.MainController"
            styleClass="root-pane">

    <!-- ═══ TOP TOOLBAR ═══ -->
    <top>
        <ToolBar styleClass="main-toolbar">
            <Label text="jvm-doctor" styleClass="app-title"/>
            <Separator orientation="VERTICAL"/>
            <Button fx:id="openFileBtn"  text="Open File"  onAction="#onOpenFile"  styleClass="toolbar-btn"/>
            <Button fx:id="pasteDumpBtn" text="Paste Dump" onAction="#onPasteDump" styleClass="toolbar-btn"/>
            <Separator orientation="VERTICAL"/>
            <Button fx:id="analyzeBtn"   text="Analyze"    onAction="#onAnalyze"   styleClass="toolbar-btn, analyze-btn"/>
        </ToolBar>
    </top>

    <!-- ═══ BOTTOM STATUS BAR ═══ -->
    <bottom>
        <HBox styleClass="status-bar">
            <Label fx:id="statusLabel" text="Ready" styleClass="status-label"/>
        </HBox>
    </bottom>

    <!-- ═══ MAIN CONTENT ═══ -->
    <center>
        <!-- 수평: 왼쪽 nav | 오른쪽 content -->
        <SplitPane dividerPositions="0.15" styleClass="main-split">

            <!-- LEFT NAV -->
            <VBox styleClass="nav-pane" minWidth="120" maxWidth="180">
                <Label text="NAVIGATION" styleClass="nav-header"/>
                <ListView fx:id="navList" styleClass="nav-list" VBox.vgrow="ALWAYS"/>
            </VBox>

            <!-- RIGHT CONTENT: 수직 — 위: 요약 | 아래: 탭 -->
            <SplitPane orientation="VERTICAL" dividerPositions="0.32" styleClass="main-split">

                <!-- 요약 행: 수평 — 왼쪽: 차트 | 오른쪽: 메트릭 -->
                <SplitPane dividerPositions="0.68" styleClass="summary-split">

                    <VBox styleClass="chart-card summary-row">
                        <padding><Insets top="10" right="12" bottom="10" left="12"/></padding>
                        <Label text="Thread States" styleClass="card-title"/>
                        <PieChart fx:id="stateChart" prefHeight="160"
                                  animated="true" labelsVisible="true" legendVisible="false"
                                  VBox.vgrow="ALWAYS"/>
                    </VBox>

                    <VBox styleClass="metrics-card summary-row" alignment="CENTER" spacing="12">
                        <padding><Insets top="10" right="12" bottom="10" left="12"/></padding>
                        <Label text="Key Metrics" styleClass="card-title"/>
                        <Label fx:id="totalLabel"    text="Total: —"     styleClass="metric-label"/>
                        <Label fx:id="blockedLabel"  text="Blocked: —"   styleClass="metric-label"/>
                        <Label fx:id="deadlockLabel" text="Deadlocks: —" styleClass="metric-label"/>
                    </VBox>

                </SplitPane>

                <!-- TAB CONTENT -->
                <TabPane fx:id="contentTabs" tabClosingPolicy="UNAVAILABLE" styleClass="content-tabs">

                    <Tab fx:id="threadsTab" text="Threads">
                        <fx:include source="thread_table.fxml" fx:id="threadTable"/>
                    </Tab>

                    <Tab fx:id="deadlockTab" text="Deadlock / Issues">
                        <fx:include source="deadlock_view.fxml" fx:id="deadlock"/>
                    </Tab>

                    <Tab text="Raw Dump">
                        <TextArea fx:id="rawTextArea" styleClass="raw-area"
                                  editable="false" wrapText="false"
                                  style="-fx-font-family: monospace; -fx-font-size: 12px;"/>
                    </Tab>

                </TabPane>

            </SplitPane>

        </SplitPane>
    </center>

</BorderPane>
