<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="io.jvmdoctor.ui.TimelineController"
      spacing="6">
    <padding><Insets top="8" right="12" bottom="8" left="12"/></padding>

    <!-- Toolbar row -->
    <HBox spacing="8" alignment="CENTER_LEFT">
        <ToggleButton fx:id="suspiciousToggle" text="Suspicious" styleClass="filter-chip, chip-problem"/>
        <ToggleButton fx:id="stuckToggle" text="Stuck" styleClass="filter-chip, chip-blocked"/>
        <ToggleButton fx:id="flappingToggle" text="Flapping" styleClass="filter-chip, chip-runnable"/>
        <ToggleButton fx:id="blockedToggle" text="Repeat Blocked" styleClass="filter-chip, chip-blocked"/>
        <ToggleButton fx:id="persistentToggle" text="Persistent" styleClass="filter-chip"/>
        <Separator orientation="VERTICAL"/>
        <Label text="Filter threads:" styleClass="filter-label"/>
        <TextField fx:id="filterField" promptText="thread name…" HBox.hgrow="ALWAYS"/>
        <Label fx:id="statusLabel" text="Add dumps to begin." styleClass="status-label"/>
    </HBox>

    <Label fx:id="sessionLabel" text="Start a session to track recurring threads across loaded dumps."
           styleClass="status-label"/>

    <Label fx:id="summaryLabel" text="The session rail on the right shows every loaded dump and helps you pivot into Pair Diff."
           styleClass="status-label"/>

    <!-- Legend -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Legend:" styleClass="filter-label"/>
        <Label text="■" style="-fx-text-fill: #3677e0;" />
        <Label text="RUNNABLE" styleClass="filter-label"/>
        <Label text="■" style="-fx-text-fill: #c73a4f;" />
        <Label text="BLOCKED" styleClass="filter-label"/>
        <Label text="■" style="-fx-text-fill: #b99132;" />
        <Label text="WAITING" styleClass="filter-label"/>
        <Label text="■" style="-fx-text-fill: #8c6a45;" />
        <Label text="TIMED_WAITING" styleClass="filter-label"/>
        <Label text="■" style="-fx-text-fill: #313244;" />
        <Label text="absent" styleClass="filter-label"/>
    </HBox>

    <Separator/>

    <!-- Heatmap -->
    <ScrollPane fx:id="heatmapScroll" VBox.vgrow="ALWAYS"
                fitToWidth="false" fitToHeight="false"
                style="-fx-background-color: #1e1e2e; -fx-background: #1e1e2e;">
        <GridPane fx:id="heatmapGrid" hgap="2" vgap="2"
                  style="-fx-background-color: #1e1e2e; -fx-padding: 8;"/>
    </ScrollPane>

</VBox>
