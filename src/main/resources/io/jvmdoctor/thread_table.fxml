<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="io.jvmdoctor.ui.ThreadTableController"
      spacing="6">
    <padding><Insets top="8" right="12" bottom="8" left="12"/></padding>

    <!-- 텍스트 필터 + 문제만 버튼 -->
    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="Filter:" styleClass="filter-label"/>
        <TextField fx:id="filterField" promptText="thread name / state / lock…" HBox.hgrow="ALWAYS"/>
        <ToggleButton fx:id="problemOnlyBtn" text="⚠ 문제만" styleClass="filter-chip, chip-problem"/>
    </HBox>

    <!-- State 칩 (동적 생성) -->
    <HBox fx:id="stateFilterBox" spacing="6" alignment="CENTER_LEFT">
        <Label text="State:" styleClass="filter-label"/>
    </HBox>

    <SplitPane orientation="VERTICAL" dividerPositions="0.6" VBox.vgrow="ALWAYS">

        <TableView fx:id="threadTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="nameCol"  text="Thread Name"  prefWidth="320"/>
                <TableColumn fx:id="stateCol" text="State"        prefWidth="130"/>
                <TableColumn fx:id="lockCol"  text="Waiting On"   prefWidth="240"/>
                <TableColumn fx:id="depthCol" text="Stack Depth"  prefWidth="90"
                             style="-fx-alignment: CENTER_RIGHT;"/>
            </columns>
            <placeholder>
                <Label text="No threads loaded. Open a dump file to begin."/>
            </placeholder>
        </TableView>

        <TextArea fx:id="stackDetail" editable="false" wrapText="false"
                  promptText="Select a thread to view its stack trace"
                  style="-fx-font-family: monospace; -fx-font-size: 12px;"/>
    </SplitPane>
</VBox>
